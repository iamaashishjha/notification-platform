# Docker Compose local defaults. Copy to .env; never put production secrets here.
APP_ENV=local
APP_PORT=8080
# Host port overrides; container-to-container ports stay unchanged.
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
API_PORT=8080
ADMIN_UI_PORT=3000
DATABASE_URL=postgres://notification:notification@postgres:5432/notification?sslmode=disable
REDIS_URL=redis://redis:6379/0
REDIS_ADDR=redis:6379
RABBITMQ_URL=amqp://notification:notification@rabbitmq:5672/
QUEUE_DRIVER=rabbitmq
JWT_SECRET=local-only-change-me
REFRESH_TOKEN_SECRET=local-only-change-me
APP_ENCRYPTION_KEY=local-only-change-me-32-bytes-minimum
INTERNAL_ADMIN_TOKEN=local-only-change-me
PROVIDER_MODE=mock
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Provider values are backend-only. Leave secrets as placeholders in examples.
EMAIL_PROVIDER=mock
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=notifications@example.com
SENDGRID_API_KEY=your-sendgrid-api-key
AWS_REGION=us-east-1
SMS_PROVIDER=mock
SPARROW_TOKEN=your-sparrow-token
SPARROW_FROM=YourBrand
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+10000000000
GENERIC_HTTP_SMS_URL=https://sms.example.com/send
GENERIC_HTTP_SMS_TOKEN=your-http-sms-token
FCM_PROJECT_ID=your-fcm-project-id
FCM_SERVICE_ACCOUNT_PATH=/run/secrets/fcm-service-account.json
WEBSOCKET_ENABLED=true

# Admin UI (public browser configuration; never add provider credentials).
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_APP_NAME=Notification Platform
